# Database
DATABASE_URL=postgresql://conf_user:conf_password@localhost:5432/conference_db

# API & CORS Configuration
NEXT_PUBLIC_API_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3003,http://localhost:3005
# Production example (web + backoffice on Netlify):
# CORS_ORIGIN=https://your-web-domain.netlify.app,https://your-backoffice-domain.netlify.app

# Google Drive API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
# API Key for public folder listing (used by /api/drive-folder endpoint)
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key

# Google Drive Folders (Root)
GOOGLE_DRIVE_FOLDER_STUDENT_DOCS=your_student_docs_folder_id
GOOGLE_DRIVE_FOLDER_ABSTRACTS=your_abstracts_folder_id
GOOGLE_DRIVE_FOLDER_SPEAKERS=your_speakers_folder_id
GOOGLE_DRIVE_FOLDER_VENUE_IMAGES=your_venue_images_folder_id

# Google Drive Abstract Subfolders - Poster Presentation
# (Optional: กำหนดค่าเพื่อเพิ่มความเร็ว upload โดยไม่ต้องค้นหา folder)
GOOGLE_DRIVE_FOLDER_POSTER_CLINICAL_PHARMACY=
GOOGLE_DRIVE_FOLDER_POSTER_SOCIAL_ADMINISTRATIVE=
GOOGLE_DRIVE_FOLDER_POSTER_COMMUNITY_PHARMACY=
GOOGLE_DRIVE_FOLDER_POSTER_PHARMACOLOGY_TOXICOLOGY=
GOOGLE_DRIVE_FOLDER_POSTER_PHARMACY_EDUCATION=
GOOGLE_DRIVE_FOLDER_POSTER_DIGITAL_PHARMACY=

# Google Drive Abstract Subfolders - Oral Presentation
GOOGLE_DRIVE_FOLDER_ORAL_CLINICAL_PHARMACY=
GOOGLE_DRIVE_FOLDER_ORAL_SOCIAL_ADMINISTRATIVE=
GOOGLE_DRIVE_FOLDER_ORAL_COMMUNITY_PHARMACY=
GOOGLE_DRIVE_FOLDER_ORAL_PHARMACOLOGY_TOXICOLOGY=
GOOGLE_DRIVE_FOLDER_ORAL_PHARMACY_EDUCATION=
GOOGLE_DRIVE_FOLDER_ORAL_DIGITAL_PHARMACY=

# JWT (Backoffice)
JWT_SECRET=your_jwt_secret_key

# NipaMail Configuration
NIPAMAIL_CLIENT_ID=your_client_id
NIPAMAIL_CLIENT_SECRET=your_client_secret
NIPAMAIL_SENDER_EMAIL=noreply@conference.example.com
NIPAMAIL_SENDER_NAME=Conference System
BASE_URL=https://conference.example.com
# Production example:
# BASE_URL=https://your-web-domain.netlify.app
CONTACT_EMAIL=info@conference.example.com
# Conference Hub URL (used by generic email templates)
CONFER_URL=https://conference-hub.example.com
CONTACT_FORM_EMAIL=contact@conference.example.com

# Stripe Payment
STRIPE_SECRET_KEY=YOUR_STRIPE_TEST_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# Pay Solutions Payment (Form Submit)
PAY_SOLUTIONS_API_KEY=your_pay_solutions_api_key
PAY_SOLUTIONS_SECRET_KEY=your_pay_solutions_secret_key
PAY_SOLUTIONS_MERCHANT_ID=12345678
PAY_SOLUTIONS_BASE_URL=https://apis.paysolutions.asia
# Optional override for form-submit redirect endpoint
PAY_SOLUTIONS_PAYMENT_FORM_ACTION_URL=https://payments.paysolutions.asia/payment

# API Base URL (used for receipt download links in emails)
API_BASE_URL=http://localhost:3002
# Production example (must be https):
# API_BASE_URL=https://your-api-domain

# Conference Web URL (for smart router redirect)
CONFERENCE_WEB_URL=http://localhost:3003
# Production example:
# CONFERENCE_WEB_URL=https://your-conference-web-domain

# KTB FASTPAY (optional - conference-web THB flow)
KTB_MERCHANT_ID=
KTB_SECURE_HASH_KEY=
KTB_CURRENCY_CODE=764
KTB_PAYMENT_FORM_URL=https://uatktbfastpay.ktb.co.th/SIT/eng/payment/payForm.jsp

# reCAPTCHA v2 (Get keys from https://www.google.com/recaptcha/admin)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Tracking ID Configuration (Abstract Submission)
# Format: {PREFIX}-O001 (Oral) or {PREFIX}-P001 (Poster)
TRACKING_ID_PREFIX=CONF
TRACKING_ID_PAD_LENGTH=3
